#!/bin/bash

# --- Configuration ---
MGMT_URL="https://api.enterprise.apigee.com/v1"
LOGIN_URL="https://login.apigee.com/oauth/token"

ORGANIZATION="your-org-name"
ENVIRONMENT="your-env-name"
USERNAME="your-email@example.com"

# --- Authentication with MFA ---
echo -n "Enter password for $USERNAME: "
read -s PASSWORD
echo ""
echo -n "Enter 6-digit MFA Code: "
read -r MFA_CODE
echo ""

echo "Exchanging credentials for an OAuth2 Bearer token..."

# Fetch the OAuth2 token
TOKEN_RESPONSE=$(curl -s \
  -H "Content-Type: application/x-www-form-urlencoded;charset=utf-8" \
  -H "Accept: application/json;charset=utf-8" \
  -H "Authorization: Basic ZWRnZWNsaTplZGdlY2xpc2VjcmV0" \
  -X POST "$LOGIN_URL" \
  -d "username=$USERNAME" \
  -d "password=$PASSWORD" \
  -d "grant_type=password" \
  -d "mfa_token=$MFA_CODE")

# Extract access token using sed
ACCESS_TOKEN=$(echo "$TOKEN_RESPONSE" | sed -n 's/.*"access_token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

if [ -z "$ACCESS_TOKEN" ]; then
    echo "Authentication failed. Please verify your password and MFA code."
    exit 1
fi

echo "Authenticated successfully! Fetching deployments..."

# 1. Get all deployed proxies
DEPLOYMENTS_JSON=$(curl -s -H "Authorization: Bearer $ACCESS_TOKEN" \
  "$MGMT_URL/organizations/$ORGANIZATION/environments/$ENVIRONMENT/deployments")

# Parse proxy names and their active revisions using sed/awk.
# This flattens the JSON array block so we can match pair mappings.
PARSED_DEPLOYMENTS=$(echo "$DEPLOYMENTS_JSON" | sed 's/},{"/\n/g')

echo "----------------------------------------------------------------------"
printf "%-35s %-10s %-s\n" "PROXY NAME" "REVISION" "BASEPATH"
echo "----------------------------------------------------------------------"

# Extract each unique proxy block
echo "$PARSED_DEPLOYMENTS" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\(.*\)"/\1/' | while read -r PROXY_NAME; do
    [ -z "$PROXY_NAME" ] && continue

    # Extract the revision associated with this specific proxy name from the deployment string
    # Matches the specific block containing the proxy name to safely retrieve its exact paired revision
    REV=$(echo "$PARSED_DEPLOYMENTS" | grep "\"name\"[[:space:]]*:[[:space:]]*\"$PROXY_NAME\"" | sed -n 's/.*"revision"[[:space:]]*:[[:space:]]*[[{]*[[:space:]]*"name"[[:space:]]*:[[:space:]]*"\([0-9]*\)".*/\1/p')
    
    if [ -z "$REV" ]; then
        # Alternative fallback pattern for flat array string mappings
        REV=$(echo "$PARSED_DEPLOYMENTS" | grep "\"name\"[[:space:]]*:[[:space:]]*\"$PROXY_NAME\"" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([0-9]*\)".*/\1/p' | head -n 1)
    fi

    [ -z "$REV" ] && continue

    # 2. Fetch the proxy revision endpoint payload to get the basepath
    PROXY_DETAILS=$(curl -s -H "Authorization: Bearer $ACCESS_TOKEN" \
      "$MGMT_URL/organizations/$ORGANIZATION/apis/$PROXY_NAME/revisions/$REV")

    # Extract basepath targets from the configuration fields or raw proxyEndpoints layout
    BASEPATHS=$(echo "$PROXY_DETAILS" | sed 's/,"/\n/g' | grep '"basepath"' | sed -n 's/.*"basepath"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | tr '\n' ',' | sed 's/,$//')

    if [ -z "$BASEPATHS" ]; then
        # Fallback to look inside the array endpoints configuration block structure if nested
        BASEPATHS=$(echo "$PROXY_DETAILS" | sed 's/ proxyEndpoints/\nproxyEndpoints/g' | grep -o '"/.*"' | tr -d '"' | tr '\n' ',' | sed 's/,$//')
    fi

    # Fallback to display standard default if empty
    if [ -z "$BASEPATHS" ]; then BASEPATHS="/"; fi

    # Output row results nicely structured
    printf "%-35s %-10s %-s\n" "$PROXY_NAME" "$REV" "$BASEPATHS"
done
